---
import { Code as AstroCode } from "astro:components";
import type { ComponentProps } from "astro/types";

type Props = Omit<ComponentProps<typeof AstroCode>, "theme">;

const props = Astro.props;
---

<AstroCode theme="css-variables" class="code" {...props} />

<style>
  .code {
    font-size: 1.7rem;
    line-height: 1.6;
    padding: 1rem 1.5rem;
    border-radius: 1px;
    border: 1px solid;
    border-color:
      var(--color-emboss-highlight)
      var(--color-emboss-shadow)
      var(--color-emboss-shadow)
      var(--color-emboss-highlight);
    margin: 0;
  }
</style>
